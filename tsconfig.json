{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/sections":         ["./app/components/sections/index.tsx"],
      "@/ui":               ["./app/components/ui/index.tsx"],
      "@/shared/hooks":     ["./app/shared/hooks/index.ts"],
      "@/shared/hooks/*":   ["./app/shared/hooks/*"],
      "@/shared/const":     ["./app/shared/const/index.ts"],
      "@/shared/const/*":   ["./app/shared/const/*"],
      "@/shared/styling/*": ["./app/shared/styling/*"],
      "@/*":                ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules"
  ]
}
